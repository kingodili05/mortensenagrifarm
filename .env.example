# Copy to .env.local and fill in real values. Never commit .env.local.

# Public site URL (used for canonical URLs, sitemap, Open Graph).
NEXT_PUBLIC_SITE_URL=https://www.mortensenagri.farm

# --- Contact form delivery (wire one of these in app/api/contact/route.ts) ---
# Resend (recommended): https://resend.com
RESEND_API_KEY=
CONTACT_TO_EMAIL=inquiry@mortensenagri.farm
CONTACT_FROM_EMAIL=website@mortensenagri.farm

# Optional: Slack incoming webhook for new enquiries
SLACK_WEBHOOK_URL=

# --- SEO verification (paste tokens from each console) ---
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
